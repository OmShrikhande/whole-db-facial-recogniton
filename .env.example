# ============================================================================
# FACE RECOGNITION SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual credentials
# 3. NEVER commit .env to version control
# 4. Add .env to .gitignore
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (SENSITIVE)
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=face_recognition_db

# For production, use dedicated user (recommended):
# MYSQL_USER=fr_user
# MYSQL_PASSWORD=secure_password_here

# ============================================================================
# FLASK APPLICATION CONFIGURATION
# ============================================================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change-me-to-secure-random-key-32-chars-minimum
FLASK_ENV=development
DEBUG=False

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Backend API URL for frontend (change for remote deployment)
API_BASE_URL=http://localhost:5000
# For production: API_BASE_URL=https://your-domain.com

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Session timeout in seconds (default 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Maximum file upload size in MB
MAX_FILE_SIZE=25

# Face recognition threshold for duplicate detection (0-1)
DUPLICATE_THRESHOLD=0.45

# Face verification threshold for matching (0-1)
VERIFICATION_THRESHOLD=0.45

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================
# Application host (0.0.0.0 for external access, 127.0.0.1 for localhost only)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Number of Gunicorn workers (formula: (2 × CPU cores) + 1)
GUNICORN_WORKERS=5

# ============================================================================
# CORS SETTINGS (For separate frontend/backend)
# ============================================================================
# Enable CORS for these origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://your-domain.com

# ============================================================================
# OPTIONAL: EMAIL/NOTIFICATION SETTINGS
# ============================================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=notifications@your-domain.com

# ============================================================================
# OPTIONAL: PERFORMANCE TUNING
# ============================================================================
# Database connection pool size
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Cache settings
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# ============================================================================
# BACKUP SETTINGS
# ============================================================================
# Backup directory path
BACKUP_DIR=/backups/face-recognition
# Backup retention days
BACKUP_RETENTION_DAYS=30
